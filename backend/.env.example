# Copy this file to .env and fill in your values.

# Storage
DATA_DIR=../data/projects
MODELS_DIR=C:\Users\juanm\Documents\Proyectos_personales\Python\DATA_LEARNING\Modelos

# SAM model — change to sam2.1_hiera_s.pt / hiera_b+.pt for better accuracy
SAM_CHECKPOINT=sam2.1_hiera_tiny.pt
SAM_CONFIG=configs/sam2.1/sam2.1_hiera_t.yaml

# CUDA device — leave empty for auto-detection (recommended)
# Set explicitly if auto-detection picks the wrong GPU.
CUDA_DEVICE=

# API server
HOST=127.0.0.1
PORT=8000
